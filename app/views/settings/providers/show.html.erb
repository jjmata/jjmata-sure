<%= content_for :page_title, "Connections" %>

<div class="space-y-6">
  <% if @encryption_error %>
    <div class="p-4 rounded-lg bg-destructive/10 border border-destructive/20">
      <div class="flex items-start gap-3">
        <%= icon("triangle-alert", class: "w-5 h-5 text-destructive shrink-0 mt-0.5") %>
        <div>
          <h3 class="font-medium text-primary"><%= t("settings.providers.encryption_error.title") %></h3>
          <p class="text-secondary text-sm mt-1"><%= t("settings.providers.encryption_error.message") %></p>
        </div>
      </div>
    </div>
  <% else %>
    <div class="space-y-2">
      <p class="text-secondary">
        Manage your family's live financial connections here. Instance-level provider credentials now live in Self-Hosting.
      </p>
    </div>

    <div class="grid gap-3 sm:grid-cols-2 xl:grid-cols-4">
      <div class="bg-container rounded-xl p-4 shadow-border-xs">
        <p class="text-xs uppercase tracking-wide text-secondary">Needs attention</p>
        <p class="mt-2 text-2xl font-medium text-primary"><%= @summary_counts[:needs_attention] %></p>
      </div>
      <div class="bg-container rounded-xl p-4 shadow-border-xs">
        <p class="text-xs uppercase tracking-wide text-secondary">Connected</p>
        <p class="mt-2 text-2xl font-medium text-primary"><%= @summary_counts[:connected] %></p>
      </div>
      <div class="bg-container rounded-xl p-4 shadow-border-xs">
        <p class="text-xs uppercase tracking-wide text-secondary">Available</p>
        <p class="mt-2 text-2xl font-medium text-primary"><%= @summary_counts[:available] %></p>
      </div>
      <div class="bg-container rounded-xl p-4 shadow-border-xs">
        <p class="text-xs uppercase tracking-wide text-secondary">Syncing</p>
        <p class="mt-2 text-2xl font-medium text-primary"><%= @summary_counts[:syncing] %></p>
      </div>
    </div>

    <% [
      [ "Needs attention", @needs_attention_cards ],
      [ "Connected", @connected_cards ],
      [ "Available to connect", @available_cards ]
    ].each do |section_title, cards| %>
      <% next if cards.empty? %>

      <section class="space-y-3">
        <div class="flex items-center gap-3">
          <h2 class="text-lg font-medium text-primary"><%= section_title %></h2>
          <%= render "shared/ruler", classes: "w-full" %>
        </div>

        <div class="space-y-4">
          <% cards.each do |card| %>
            <%= render "settings/providers/connection_card", card: card %>
          <% end %>
        </div>
      </section>
    <% end %>
  <% end %>
</div>
